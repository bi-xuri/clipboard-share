{
  "manifest_version": 3,
  "name": "LAN Clipboard Sync",
  "version": "1.0.0",
  "description": "Sync clipboard text over a local WebSocket server.",
  "permissions": [
    "alarms",
    "clipboardRead",
    "clipboardWrite",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "ws://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LAN Clipboard Sync",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html",
        "offscreen.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
